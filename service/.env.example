PORT=3000
MONGODB_URI=mongodb://127.0.0.1:27017/lead-pipeline
CORS_ORIGIN=http://localhost:5173

JWT_ACCESS_SECRET=change-me
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me
JWT_REFRESH_EXPIRES_IN=7d

SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=ChangeMe123!
SEED_ADMIN_NAME=Admin

# Redis (BullMQ job queue)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
# Set to "true" for TLS-only providers like Upstash (rediss://)
REDIS_TLS=false

# Scraper
# Identify the bot honestly and give site owners a way to contact you - this
# is checked against robots.txt rules and sent as the request User-Agent.
SCRAPER_USER_AGENT=LeadGenBot/1.0 (+https://example.com/bot; contact@example.com)
# Minimum delay (ms) between requests to the same domain, used when robots.txt
# does not specify a Crawl-delay.
SCRAPER_DEFAULT_CRAWL_DELAY_MS=2000
SCRAPER_REQUEST_TIMEOUT_MS=15000
# Number of scrape tasks a worker processes concurrently across all domains
# (per-domain pacing is handled separately via SCRAPER_DEFAULT_CRAWL_DELAY_MS).
SCRAPER_WORKER_CONCURRENCY=5
